# LLM через OpenAI-сумісний endpoint (OpenRouter), як у решті портфоліо.
# Без ключа працює лише rules-baseline (це навмисно — щоб числа правил
# можна було відтворити будь-кому без витрат на API).
OPENROUTER_API_KEY=
# Модель для бенчу. Структуроване завдання — дорога модель не потрібна (це теж вимірюємо).
# Якщо на ключі стоїть $0-ліміт витрат (блокує платні моделі) — беріть безкоштовну,
# напр. openai/gpt-oss-120b:free. Саме на ній заміряні поточні LLM-числа в README.
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Захист ендпоінта /api/misses (лог запитів клієнтів). Якщо заданий —
# доступ лише з ?token=<значення>. ОБОВ'ЯЗКОВО виставити перед публічним деплоєм.
MISSES_TOKEN=
