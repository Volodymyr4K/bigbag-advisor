# LLM через OpenAI-сумісний endpoint (OpenRouter), як у решті портфоліо.
# Без ключа працює лише rules-baseline (це навмисно — щоб числа правил
# можна було відтворити будь-кому без витрат на API).
OPENROUTER_API_KEY=
# Модель для бенчу. Структуроване завдання — дорога модель не потрібна (це теж вимірюємо).
# Якщо на ключі стоїть $0-ліміт витрат (блокує платні моделі) — беріть безкоштовну
# instruct-модель, напр. nvidia/nemotron-3-super-120b-a12b:free або nex-agi/nex-n2-pro:free
# (саме на таких заміряні поточні LLM-числа в README). НЕ reasoning-моделі — вони повертають
# прозу замість JSON.
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Захист ендпоінта /api/misses (лог запитів клієнтів). Ендпоінт безпечний за замовчуванням:
# у продакшені закритий без цієї змінної. Задайте значення, щоб увімкнути перегляд (з ?token=).
MISSES_TOKEN=
